<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="5.0" xmlns="http://ns.adobe.com/extension/metadata/1.0">
  <ExtensionList>
    <Extension Id="com.disanbd2.ledgenerator">
      <Name>3D RGB LED Generator</Name>
      <Version>1.0.0</Version>
      <ExecEnvironment>
        <Host Name="ILST" Version="25.0" />
      </ExecEnvironment>
      <UI>
        <Type>Panel</Type>
        <Geometry>
          <Size>
            <Width>400</Width>
            <Height>600</Height>
          </Size>
        </Geometry>
      </UI>
      <RequiredRuntime>
        <Name>AdobeUXP</Name>
        <Version>7.0</Version>
      </RequiredRuntime>
    </Extension>
  </ExtensionList>
  <ExecutionEnvironment>
    <Localization>
      <Language>en_US</Language>
    </Localization>
  </ExecutionEnvironment>
</ExtensionManifest>